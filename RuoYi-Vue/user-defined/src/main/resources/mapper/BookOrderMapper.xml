<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.BookOrderMapper">

    <resultMap type="com.ruoyi.domain.entity.BookOrder" id="BookOrderResult">
        <result property="orderId"    column="order_id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="venueId"    column="venue_id"    />
        <result property="userId"    column="user_id"    />
        <result property="reserveStart"    column="reserve_start"    />
        <result property="reserveEnd"    column="reserve_end"    />
        <result property="duration"    column="duration"    />
        <result property="status"    column="status"    />
        <result property="reason"    column="reason"    />
        <result property="payAmount"    column="pay_amount"    />
        <result property="payStatus"    column="pay_status"    />
        <result property="payTime"    column="pay_time"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <resultMap type="com.ruoyi.domain.vo.BookOrderVo" id="BookOrderVoResult">
        <result property="orderId"    column="order_id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="venueId"    column="venue_id"    />
        <result property="userId"    column="user_id"    />
        <result property="reserveStart"    column="reserve_start"    />
        <result property="reserveEnd"    column="reserve_end"    />
        <result property="duration"    column="duration"    />
        <result property="status"    column="status"    />
        <result property="reason"    column="reason"    />
        <result property="payAmount"    column="pay_amount"    />
        <result property="payStatus"    column="pay_status"    />
        <result property="payTime"    column="pay_time"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="nickName"    column="nick_name"    />
        <result property="tableCode"    column="table_code"    />
    </resultMap>

    <sql id="selectBookOrderVo">
        select bo.order_id, bo.order_no, bo.venue_id, bo.user_id, bo.reserve_start, bo.reserve_end, bo.duration, bo.status, bo.reason, bo.pay_amount, bo.pay_status, bo.pay_time, bo.create_time, bo.update_time, bo.del_flag,
        u.nick_name, t.table_code
        from t_book_order bo
        left join sys_user u on bo.user_id = u.user_id
        left join t_ball_table t on bo.venue_id = t.table_id
    </sql>

    <select id="selectBookOrderList" parameterType="com.ruoyi.domain.entity.BookOrder" resultMap="BookOrderVoResult">
        <include refid="selectBookOrderVo"/>
        <where>
            <if test="orderNo != null  and orderNo != ''"> and bo.order_no = #{orderNo}</if>
            <if test="venueId != null "> and bo.venue_id = #{venueId}</if>
            <if test="userId != null "> and bo.user_id = #{userId}</if>
            <if test="reserveStart != null "> and bo.reserve_start >= #{reserveStart}</if>
            <if test="reserveStartMatch != null and reserveStartMatch != ''"> and date_format(bo.reserve_start, '%Y-%m-%d %H:%i:%s') like concat(#{reserveStartMatch}, '%')</if>
            <if test="reserveEnd != null "> and bo.reserve_end = #{reserveEnd}</if>
            <if test="duration != null "> and bo.duration = #{duration}</if>
            <if test="status != null "> and bo.status = #{status}</if>
            <if test="reason != null  and reason != ''"> and bo.reason = #{reason}</if>
            <if test="nickName != null  and nickName != ''"> and u.nick_name like concat('%', #{nickName}, '%')</if>
            <if test="tableCode != null  and tableCode != ''"> and t.table_code like concat('%', #{tableCode}, '%')</if>
        </where>
        order by bo.create_time desc
    </select>

    <select id="selectBookOrderByOrderId" parameterType="Long" resultMap="BookOrderVoResult">
        <include refid="selectBookOrderVo"/>
        where order_id = #{orderId}
    </select>

    <insert id="insertBookOrder" parameterType="com.ruoyi.domain.entity.BookOrder" useGeneratedKeys="true" keyProperty="orderId">
        insert into t_book_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null">order_no,</if>
            <if test="venueId != null">venue_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="reserveStart != null">reserve_start,</if>
            <if test="reserveEnd != null">reserve_end,</if>
            <if test="duration != null">duration,</if>
            <if test="status != null">status,</if>
            <if test="reason != null">reason,</if>
            <if test="payAmount != null">pay_amount,</if>
            <if test="payStatus != null">pay_status,</if>
            <if test="payTime != null">pay_time,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null">#{orderNo},</if>
            <if test="venueId != null">#{venueId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="reserveStart != null">#{reserveStart},</if>
            <if test="reserveEnd != null">#{reserveEnd},</if>
            <if test="duration != null">#{duration},</if>
            <if test="status != null">#{status},</if>
            <if test="reason != null">#{reason},</if>
            <if test="payAmount != null">#{payAmount},</if>
            <if test="payStatus != null">#{payStatus},</if>
            <if test="payTime != null">#{payTime},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
        </trim>
    </insert>

    <update id="updateBookOrder" parameterType="com.ruoyi.domain.entity.BookOrder">
        update t_book_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderNo != null">order_no = #{orderNo},</if>
            <if test="venueId != null">venue_id = #{venueId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="reserveStart != null">reserve_start = #{reserveStart},</if>
            <if test="reserveEnd != null">reserve_end = #{reserveEnd},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="status != null">status = #{status},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="payAmount != null">pay_amount = #{payAmount},</if>
            <if test="payStatus != null">pay_status = #{payStatus},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where order_id = #{orderId}
    </update>

    <delete id="deleteBookOrderByOrderId" parameterType="Long">
        delete from t_book_order where order_id = #{orderId}
    </delete>

    <delete id="deleteBookOrderByOrderIds" parameterType="String">
        delete from t_book_order where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>

    <select id="countBookOrderByTimeRange" resultType="int">
        select count(1) from t_book_order
        where status in (1, 4)
        and date_format(reserve_start, '%Y-%m-%d') = date_format(now(), '%Y-%m-%d')
        and date_format(reserve_start, '%H:%i:%s') &gt;= #{startTime}
        and date_format(reserve_start, '%H:%i:%s') &lt;= #{endTime}
    </select>

    <select id="selectDailyRevenue" resultType="java.util.Map">
        select date(pay_time) as revenue_date, sum(pay_amount) as total_amount
        from t_book_order
        where pay_status = 1
        and pay_time >= #{startDate}
        and pay_time &lt; DATE_ADD(#{endDate}, INTERVAL 1 DAY)
        group by date(pay_time)
        order by revenue_date
    </select>
</mapper>